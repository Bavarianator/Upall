# ==============================================================================
# HAUPT-UPDATE-LOGIK
# ==============================================================================

run_updates() {
    print_sep "-"
    log_upall "Update-Prozess wird gestartet..."
    print_sep "-"
    echo ""

    case "${PACKAGE_MANAGER}" in
        apt|apt-get)  update_apt ;;
        dnf)          update_dnf ;;
        yum)          update_yum ;;
        pacman)       update_pacman ;;
        zypper)       update_zypper ;;
        emerge)       update_emerge ;;
        unknown)
            log_error "Kein unterstuetzter Paketmanager. Abbruch."
            return 1
            ;;
        *)
            log_error "Unbekannt: ${PACKAGE_MANAGER}"
            return 1
            ;;
    esac

    update_flatpak
    update_snap
    update_firmware
}

# ==============================================================================
# HILFE & VERSION
# ==============================================================================

show_help() {
    cat << HILFE_ENDE

${SCRIPT_NAME} v${SCRIPT_VERSION} - Universal Linux Updater

NUTZUNG:
    UPALL [OPTION]

OPTIONEN:
    (keine)       Normales vollstaendiges Update
    --nerd        Interaktiver Nerd Mode mit Menue
    --setup       Ersteinrichtung / Setup-Wizard
    --dry-run     Simulation (keine Aenderungen)
    --quiet       Stille Ausfuehrung (nur Fehler)
    --force       Keine Rueckfragen
    --info        Systeminformationen anzeigen
    --version     Version anzeigen
    --help        Diese Hilfe anzeigen

KONFIGURATION:
    ${CONFIG_FILE}

LOG-DATEIEN:
    ${LOG_DIR}

BEISPIELE:
    UPALL                  Volles System-Update
    UPALL --nerd           Erweitertes Menue
    UPALL --dry-run        Simulation
    UPALL --quiet --force  Automatisch, still

HILFE_ENDE
}

show_version() {
    echo "${SCRIPT_NAME} v${SCRIPT_VERSION}"
}

# ==============================================================================
# ARGUMENTE VERARBEITEN
# ==============================================================================

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --nerd)     NERD_MODE=true ;;
            --setup)    SETUP_MODE=true ;;
            --dry-run)  DRY_RUN=true ;;
            --quiet)    QUIET_MODE=true; LOG_LEVEL="quiet" ;;
            --force)    FORCE_MODE=true ;;
            --info)     SHOW_INFO=true ;;
            --version)  show_version; exit 0 ;;
            --help|-h)  show_help; exit 0 ;;
            *)
                log_error "Unbekannte Option: $1"
                echo "Verwende --help fuer Hilfe."
                exit 1
                ;;
        esac
        shift
    done
}

# ==============================================================================
# MAIN
# ==============================================================================

main() {
    # Bash-Version pruefen
    if (( BASH_VERSINFO[0] < 4 )); then
        echo "[${SCRIPT_NAME}] [ERROR] Bash 4.0+ erforderlich (aktuell: ${BASH_VERSION})" >&2
        exit 1
    fi

    setup_colors
    parse_args "$@"
    setup_logging
    setup_traps
    acquire_lock

    # Distro erkennen
    detect_distro

    # Konfiguration laden
    load_config

    START_TIME=$(date +%s)

    # Modus-Auswahl
    if [[ "${SETUP_MODE}" == "true" ]]; then
        run_setup
        exit 0
    fi

    if [[ "${SHOW_INFO}" == "true" ]]; then
        show_system_info
        exit 0
    fi

    if [[ "${NERD_MODE}" == "true" ]]; then
        nerd_menu
        exit 0
    fi

    # --- Standard-Modus: Vollstaendiges Update ---
    print_header

    if [[ "${PACKAGE_MANAGER}" == "unknown" ]]; then
        log_error "Kein unterstuetzter Paketmanager gefunden. Abbruch."
        exit 1
    fi

    # Root-Check
    if ! is_root && ! cmd_exists sudo; then
        log_error "Root-Rechte oder sudo erforderlich."
        exit 1
    fi

    # Sudo vorab authentifizieren
    if ! is_root && cmd_exists sudo; then
        log_info "Root-Rechte werden angefordert..."
        if ! sudo -v; then
            log_error "sudo-Authentifizierung fehlgeschlagen."
            exit 1
        fi
    fi

    if [[ "${DRY_RUN}" == "true" ]]; then
        log_info "DRY-RUN Modus aktiv. Keine Aenderungen."
        echo ""
    fi

    create_backup
    calc_steps
    run_updates
    show_summary
    check_reboot

    exit "${ERRORS_COUNT}"
}

# Script starten
main "$@"
